Bootstrap: docker
From: nvcr.io/nvidia/dgl:25.08-py3

%files
	requirements.txt /workspace/requirements.txt
	src /workspace/src

%post
	apt-get update && apt-get install -y --no-install-recommends build-essential python3 python3-pip python3-dev wget tar libcurl4 openssl iputils-ping curl wget proxychains4 && apt-get clean
	python3 -m pip install --upgrade pip
	pip install -r /workspace/requirements.txt
	mkdir -p /workspace/config

	cd ~
	apt-get autoremove -y
	apt-get clean
	rm -rf /root/.cache
	rm -rf /var/lib/apt/lists/*

%runscript
	exec python3 "$@"